<?xml version="1.0" encoding="utf-8"?>
<Project>
    <PropertyGroup>
        <WebPublishMethod>FileSystem</WebPublishMethod>
        <PublishProvider>FileSystem</PublishProvider>
        <PublishUrl>F:\SynchronousMp3WebPlayer\</PublishUrl>
        <PublishDir>F:\SynchronousMp3WebPlayer\</PublishDir>
        <Configuration>Release</Configuration>
        <TargetFramework>net9.0</TargetFramework>
        <RuntimeIdentifier>win-x64</RuntimeIdentifier>
        <SelfContained>true</SelfContained>
        <ControlWindowsServiceOnPublish>true</ControlWindowsServiceOnPublish>
    </PropertyGroup>

    <Target Name="StopSynchronousMp3WebPlayerService"
            BeforeTargets="GenerateSingleFileBundle;Publish"
            Condition="'$(ControlWindowsServiceOnPublish)' == 'true'">
        <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;$service = Get-Service -Name 'SynchronousMp3WebPlayer' -ErrorAction SilentlyContinue; if ($service -and $service.Status -ne 'Stopped') { sc.exe stop SynchronousMp3WebPlayer; $service.WaitForStatus('Stopped', [TimeSpan]::FromSeconds(45)) }&quot;" />
    </Target>

    <Target Name="StartSynchronousMp3WebPlayerService"
            AfterTargets="Publish"
            Condition="'$(ControlWindowsServiceOnPublish)' == 'true'">
        <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;$service = Get-Service -Name 'SynchronousMp3WebPlayer' -ErrorAction SilentlyContinue; if ($service) { sc.exe start SynchronousMp3WebPlayer; $service.WaitForStatus('Running', [TimeSpan]::FromSeconds(45)) }&quot;" />
    </Target>
</Project>
